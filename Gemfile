group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-feed"
end

# Windows / JRuby timezone data
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
# Faster file watching on macOS
gem "wdm", "~> 0.1", platforms: [:mingw, :mswin, :x64_mingw]
